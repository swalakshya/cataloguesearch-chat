EXTERNAL_API_BASE_URL=http://host.docker.internal:8000
LLM_DEFAULT_CONTENT_TYPES=Pravachan,Granth
LLM_ALLOWED_CONTENT_TYPES=Pravachan,Granth,Books
DEFAULT_ANSWER_FORMAT=structured
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=YOUR_GEMINI_KEY
OPENAI_API_KEY=YOUR_OPENAI_KEY
LLM_SERVICE_PORT=8012
LLM_SESSION_IDLE_TIMEOUT_SEC=900
WORKFLOW_TOOL_CALL_BUDGET=25
LOG_LEVEL=info
LOGS_DIR=logs
SESSION_DB_PATH=
